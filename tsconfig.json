{
  // Type-checking only — the .js files ship as-is, there is no build step.
  // Run: npx tsc --noEmit   (CI does this on every push)
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "node",
    // deliberately non-strict: the goal is catching field typos on the
    // shared game/entity objects, not annotating every parameter
    "strict": false,
    "lib": ["es2022", "dom", "dom.iterable"]
  },
  "include": ["mooncraft/js/**/*"]
}
